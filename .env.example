# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=db_sport
DB_USER=postgres
DB_PASSWORD=
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000
LOG_LEVEL=info

# Configuraciones de sincronización de base de datos
DB_FORCE_SYNC=false          # Si es true, elimina y recrea todas las tablas (¡CUIDADO: borra datos!)
DB_ALTER_SYNC=false         # Si es true, altera las tablas existentes para coincidir con los modelos

# ============================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================
PORT=5010                   # Puerto en el que se ejecutará el servidor
HOST=localhost              # Host/dirección IP del servidor (localhost, 0.0.0.0, etc.)
NODE_ENV=development        # Entorno de ejecución (development, production, test)

# ============================================
# CONFIGURACIÓN DE AUTENTICACIÓN JWT
# ============================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production  # Clave secreta para firmar tokens JWT (¡CAMBIAR EN PRODUCCIÓN!)
JWT_EXPIRES=24h             # Tiempo de expiración de los tokens JWT (24h, 7d, 30m, etc.)

# ============================================
# CONFIGURACIÓN DE CORS
# ============================================
FRONTEND_URL=http://localhost:5173  # URL del frontend para configurar CORS correctamente
CORS_ORIGIN=http://localhost:5173,http://localhost:4173   # Orígenes permitidos para requests CORS (separados por comas)

# ============================================
# CONFIGURACIÓN DE DATOS INICIALES
# ============================================
SEED_INITIAL_DATA=true      # Si es true, pobla la base de datos con datos iniciales (países, roles, tipos de pago)

# ============================================
# CONFIGURACIÓN DE REDIS (OPCIONAL)
# ============================================
REDIS_ENABLED=true  # Habilitar/deshabilitar Redis (true/false)
REDIS_URL=redis://localhost:6379  # URL de conexión a Redis
REDIS_TTL=3600  # Tiempo de vida de los datos en caché (segundos)

# ============================================
# MONITOREO DE ERRORES — SENTRY (OPCIONAL)
# ============================================
# Obtener DSN en: https://sentry.io → Project Settings → Client Keys
# Si no se define SENTRY_DSN, Sentry se deshabilita automáticamente
SENTRY_DSN=  # https://xxx@xxx.ingest.sentry.io/xxx

# ============================================
# PASARELAS DE PAGO — STRIPE (Tarjeta crédito/débito)
# ============================================
# Flujo moderno con PaymentIntents (NO usar charges.create — deprecated):
#   1. POST /bookings/payment-intent  → backend crea PI, devuelve client_secret
#   2. Frontend confirma con Stripe.js usando client_secret
#   3. POST /bookings con payment_details.payment_intent_id → backend verifica y confirma reserva
#   4. Webhook POST /bookings/webhooks/stripe como capa de confiabilidad
#
# Para obtener tus claves: https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY: usar sk_test_... en dev, sk_live_... en producción
# STRIPE_PUBLIC_KEY: usar pk_test_... en dev, pk_live_... en producción (va al frontend)
# STRIPE_WEBHOOK_SECRET: obtener con: stripe listen --forward-to localhost:5010/api/bookings/webhooks/stripe
STRIPE_SECRET_KEY=sk_test_..._TU_SECRET_KEY_DE_STRIPE
STRIPE_PUBLIC_KEY=pk_test_..._TU_PUBLIC_KEY_DE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_..._TU_WEBHOOK_SECRET_DE_STRIPE

